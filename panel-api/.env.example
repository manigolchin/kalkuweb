# Copy this file to panel-api/.env on the production server, fill in values, then
# `docker compose -f docker-compose.prod.yml up -d`.
# panel-api/.env is gitignored — never commit a real secret.

# Random 64-char hex (openssl rand -hex 32). If unset, the API mints a per-process
# secret and every restart logs everyone out. Set this for stable sessions.
JWT_SECRET=

# Initial seed user — only used the very first time the DB is created.
# After that, change credentials inside the app.
SEED_EMAIL=mani_golchin@kalku.de
SEED_NAME=Mani Golchin
SEED_PASSWORD=
SEED_COMPANY=
