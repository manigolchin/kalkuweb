# Required by Traefik routing, leave PORT 3000
PORT=3000

# CORS (comma-separated origins)
CORS_ORIGINS=https://kalku.kalkus.de,https://kalku.de,https://www.kalku.de

# SMTP for outbound lead notifications (optional but recommended)
# Beispiel: Strato/IONOS/Gmail/Resend
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="KALKU Web <noreply@kalku.de>"
LEAD_EMAIL_TO=it@kalku.de

# Pipedrive (optional)
PIPEDRIVE_API_TOKEN=
PIPEDRIVE_OWNER_ID=
